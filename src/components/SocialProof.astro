---
const stats = [
  { value: 'RD 742/2013', label: 'Marco legal aplicado al flujo diario de registro' },
  { value: 'XML SILOE', label: 'Exportacion oficial compatible con Sanidad' },
  { value: 'Trazabilidad', label: 'Historial centralizado de lecturas y laboratorio' },
  { value: 'Multi-tenant', label: 'Separacion de datos por establecimiento y piscina' },
];
---

<section class="social-proof">
  <div class="container">
    <div class="sp-header">
      <span class="section-label">Cumplimiento legal</span>
      <h2>Menos burocracia, mas control</h2>
      <p>
        SILOE Generator esta pensado para cumplir el RD 742/2013 sin depender de
        hojas sueltas ni excels rotos. Registra, valida y exporta con un flujo claro.
      </p>
    </div>

    <div class="sp-grid">
      {stats.map(s => (
        <div class="sp-stat">
          <div class="sp-value">{s.value}</div>
          <div class="sp-label">{s.label}</div>
        </div>
      ))}
    </div>

    <div class="sp-quote">
      <blockquote>"Software que funciona. Sin humo."</blockquote>
      <cite>Sin frases vacias: foco en normativa, datos y operacion diaria.</cite>
    </div>
  </div>
</section>

<style>
.social-proof {
  background: var(--chumbo-skin);
  padding: 5.5rem 0;
}

.sp-header {
  margin-bottom: 3rem;
}
.sp-header .section-label { color: var(--chumbo-flesh); }

.sp-header h2 {
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  color: #fff;
  margin-bottom: .75rem;
}

.sp-header p {
  font-size: 1rem;
  color: rgba(255,255,255,.75);
  max-width: 480px;
}

.sp-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1rem;
  margin-bottom: 3.5rem;
}

.sp-stat {
  background: rgba(255,255,255,.1);
  border: 1px solid rgba(255,255,255,.18);
  border-radius: var(--radius-md);
  padding: 1.5rem 1.75rem;
}

.sp-value {
  font-family: var(--font-heading);
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--chumbo-flesh);
  margin-bottom: .35rem;
}

.sp-label {
  font-size: .875rem;
  color: rgba(255,255,255,.7);
  line-height: 1.4;
}

.sp-quote {
  border-left: 3px solid var(--chumbo-flesh);
  padding-left: 1.5rem;
}

blockquote {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 700;
  color: #fff;
  font-style: italic;
  margin-bottom: .5rem;
}

cite {
  font-size: .875rem;
  color: rgba(255,255,255,.6);
  font-style: normal;
}
</style>

