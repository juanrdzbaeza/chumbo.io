---
export interface Props {
  standalone?: boolean;
}
const { standalone = false } = Astro.props;

const tiers = [
  {
    name: 'Starter',
    price: '69',
    tag: null,
    for: 'Un establecimiento con piscina',
    note: 'Ideal para hoteles independientes, campings o comunidades de vecinos.',
  },
  {
    name: 'Pro',
    price: '129',
    tag: 'El más elegido',
    for: 'Hasta 5 establecimientos',
    note: 'Para cadenas pequeñas o gestoras con varias instalaciones.',
  },
  {
    name: 'Enterprise',
    price: '299',
    tag: null,
    for: 'Establecimientos ilimitados',
    note: 'Para grandes cadenas hoteleras o gestoras sin límite de crecimiento.',
  },
];
---

<section class="pricing" id="precios">
  <div class="container">
    {!standalone && <span class="section-label section-label--dark">Precios</span>}

    <h2 class="pricing-title">
      {standalone ? 'Planes y precios' : 'Sin letra pequeña'}
    </h2>
    <p class="pricing-sub">
      Suscripción mensual. Sin permanencia. Cancela cuando quieras.<br />
      Durante la <strong>beta pública</strong> todos los planes incluyen
      acceso completo a Siloe-Generator — sin funcionalidades recortadas.
      Los detalles definitivos de cada plan los estamos cerrando;
      si tienes prisa, escríbenos y lo hablamos.
    </p>

    <!-- Beta notice -->
    <div class="beta-notice">
      <span class="beta-dot"></span>
      <span>
        <strong>Beta pública activa.</strong> Los precios y límites exactos
        de cada plan pueden ajustarse antes del lanzamiento oficial.
        Lo que no cambia: el precio que empieces a pagar es el que mantienes.
      </span>
    </div>

    <div class="tiers-grid">
      {tiers.map(t => (
        <div class={`tier-card${t.tag ? ' tier-card--featured' : ''}`}>
          {t.tag && <div class="tier-tag">{t.tag}</div>}
          <div class="tier-header">
            <h3 class="tier-name">{t.name}</h3>
            <div class="tier-price">
              <span class="tier-amount">{t.price} €</span>
              <span class="tier-period">/mes</span>
            </div>
          </div>
          <p class="tier-for">{t.for}</p>
          <p class="tier-note">{t.note}</p>
          <a
            href="https://siloegenerator.chumbo.io/registro"
            class={`btn tier-btn${t.tag ? ' btn-primary' : ' btn-outline-dark'}`}
            target="_blank"
            rel="noopener"
          >
            Empezar con {t.name}
          </a>
        </div>
      ))}
    </div>

    <div class="pricing-cta-note">
      <p>
        ¿No encaja ningún plan o tienes más de 5 establecimientos?{' '}
        <a href="mailto:soporte@chumbo.io">Escríbenos</a>
        {' '}y lo resolvemos sin formularios de 12 campos.
      </p>
    </div>
  </div>
</section>

<style>
.pricing {
  background: var(--bg-light);
  padding: 6rem 0;
  border-top: 1px solid var(--border);
}

.pricing-title {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  color: var(--text-dark);
  margin-bottom: .75rem;
}

.pricing-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 600px;
  margin-bottom: 2rem;
  line-height: 1.75;
}
.pricing-sub strong { color: var(--text-dark); font-weight: 600; }

/* Beta notice */
.beta-notice {
  display: flex;
  align-items: flex-start;
  gap: .75rem;
  background: rgba(155,29,53,.06);
  border: 1px solid rgba(155,29,53,.2);
  border-radius: var(--radius-md);
  padding: 1rem 1.25rem;
  margin-bottom: 3rem;
  font-size: .875rem;
  color: var(--text-dark);
  max-width: 640px;
  line-height: 1.6;
}
.beta-notice strong { color: var(--chumbo-skin); }
.beta-dot {
  flex-shrink: 0;
  margin-top: 4px;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--chumbo-skin);
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: .35; }
}

/* Tiers grid */
.tiers-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}

.tier-card {
  position: relative;
  background: var(--bg-white);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 2rem;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: 1rem;
  transition: box-shadow .2s;
}
.tier-card:hover { box-shadow: var(--shadow-md); }

.tier-card--featured {
  border-color: var(--chumbo-skin);
  box-shadow: 0 0 0 2px var(--chumbo-skin), var(--shadow-md);
}

.tier-tag {
  position: absolute;
  top: -13px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--chumbo-skin);
  color: #fff;
  font-family: var(--font-heading);
  font-size: .72rem;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: .25rem .85rem;
  border-radius: 999px;
  white-space: nowrap;
}

.tier-name {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-dark);
}

.tier-price {
  display: flex;
  align-items: baseline;
  gap: .25rem;
}
.tier-amount {
  font-family: var(--font-heading);
  font-size: 2.6rem;
  font-weight: 700;
  color: var(--text-dark);
  line-height: 1;
}
.tier-period {
  font-size: .9rem;
  color: var(--text-muted);
}

.tier-for {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  color: var(--chumbo-skin);
  line-height: 1.3;
}

.tier-note {
  font-size: .875rem;
  color: var(--text-muted);
  line-height: 1.6;
  flex: 1;
}

.tier-btn {
  width: 100%;
  justify-content: center;
  margin-top: auto;
}

.pricing-cta-note {
  text-align: center;
  font-size: .875rem;
  color: var(--text-muted);
  border-top: 1px solid var(--border);
  padding-top: 1.75rem;
}
.pricing-cta-note a {
  color: var(--chumbo-skin);
  font-weight: 500;
}
</style>

