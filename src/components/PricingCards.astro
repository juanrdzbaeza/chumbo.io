---
export interface Props {
  standalone?: boolean;
}
const { standalone = false } = Astro.props;

const tiers = [
  {
    name: 'Beta gratuita',
    price: '0',
    priceSuffix: '',
    tag: null,
    isFree: true,
    limits: '1 establecimiento · 1 piscina',
    for: 'Pruébalo sin comprometerte',
    note: 'Acceso completo durante la beta pública. Sin tarjeta. Cuando te convenza, subes de plan y tus datos siguen ahí.',
    cta: 'Empezar gratis',
    ctaClass: 'btn-outline-dark',
    warning: 'Temporal durante la beta pública',
  },
  {
    name: 'Starter',
    price: '69',
    priceSuffix: '€/mes',
    tag: null,
    isFree: false,
    limits: 'Hasta 2 piscinas',
    for: 'El establecimiento de toda la vida',
    note: 'Un hotel, un camping o una comunidad de vecinos con una o dos piscinas. Sin complicaciones.',
    cta: 'Empezar con Starter',
    ctaClass: 'btn-outline-dark',
    warning: null,
  },
  {
    name: 'Pro',
    price: '129',
    priceSuffix: '€/mes',
    tag: 'El más elegido',
    isFree: false,
    limits: 'Hasta 6 piscinas',
    for: 'Establecimiento mediano o varios hoteles',
    note: 'Para gestoras, cadenas pequeñas o cualquier instalación con varias piscinas bajo el mismo techo.',
    cta: 'Empezar con Pro',
    ctaClass: 'btn-primary',
    warning: null,
  },
  {
    name: 'Enterprise',
    price: '299',
    priceSuffix: '€/mes',
    tag: null,
    isFree: false,
    limits: 'Piscinas ilimitadas',
    for: 'Cadenas hoteleras · Empresas de mantenimiento',
    note: 'Sin límite de piscinas ni establecimientos. Para los que gestionan muchas instalaciones y no quieren estar mirando contadores.',
    cta: 'Hablar con nosotros',
    ctaClass: 'btn-outline-dark',
    warning: null,
  },
];
---

<section class="pricing" id="precios">
  <div class="container">
    {!standalone && <span class="section-label section-label--dark">Precios</span>}

    <h2 class="pricing-title">
      {standalone ? 'Planes y precios' : 'Sin letra pequeña'}
    </h2>
    <p class="pricing-sub">
      Suscripción mensual. Sin permanencia. Cancela cuando quieras.<br />
      Empieza gratis con la beta — sin tarjeta, sin trampa.
    </p>

    <div class="tiers-grid">
      {tiers.map(t => (
        <div class={`tier-card${t.tag ? ' tier-card--featured' : ''}${t.isFree ? ' tier-card--free' : ''}`}>
          {t.tag && <div class="tier-tag">{t.tag}</div>}

          <div class="tier-header">
            <h3 class="tier-name">{t.name}</h3>
            <div class="tier-price">
              {t.isFree
                ? <span class="tier-amount tier-amount--free">Gratis</span>
                : <><span class="tier-amount">{t.price} €</span><span class="tier-period">/mes</span></>
              }
            </div>
          </div>

          <div class="tier-limits">{t.limits}</div>
          <p class="tier-for">{t.for}</p>
          <p class="tier-note">{t.note}</p>

          {t.warning && (
            <p class="tier-warning">⏳ {t.warning}</p>
          )}

          <a
            href="https://siloegenerator.chumbo.io/precios"
            class={`btn ${t.ctaClass} tier-btn`}
            target="_blank"
            rel="noopener"
          >
            {t.cta}
          </a>
        </div>
      ))}
    </div>

    <div class="pricing-cta-note">
      <p>
        ¿Más de 6 piscinas o necesitas algo a medida?{' '}
        <a href="mailto:soporte@chumbo.io">Escríbenos</a>
        {' '}y lo resolvemos sin formularios de 12 campos.
      </p>
    </div>
  </div>
</section>

<style>
.pricing {
  background: var(--bg-light);
  padding: 6rem 0;
  border-top: 1px solid var(--border);
}

.pricing-title {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  color: var(--text-dark);
  margin-bottom: .75rem;
}

.pricing-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 600px;
  margin-bottom: 2.5rem;
  line-height: 1.75;
}

/* Grid: 4 columnas desktop · 2×2 tablet · 1 columna móvil */
.tiers-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
  margin-bottom: 2.5rem;
}
@media (max-width: 1024px) {
  .tiers-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 560px) {
  .tiers-grid { grid-template-columns: 1fr; }
}

/* Cards */
.tier-card {
  position: relative;
  background: var(--bg-white);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: .875rem;
  transition: box-shadow .2s;
}
.tier-card:hover { box-shadow: var(--shadow-md); }

.tier-card--featured {
  border-color: var(--chumbo-skin);
  box-shadow: 0 0 0 2px var(--chumbo-skin), var(--shadow-md);
}

.tier-card--free {
  border-style: dashed;
  border-color: var(--chumbo-flesh);
  background: rgba(244,165,35,.03);
}

.tier-tag {
  position: absolute;
  top: -13px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--chumbo-skin);
  color: #fff;
  font-family: var(--font-heading);
  font-size: .72rem;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: .25rem .85rem;
  border-radius: 999px;
  white-space: nowrap;
}

.tier-name {
  font-size: .95rem;
  font-weight: 700;
  color: var(--text-dark);
}

.tier-price {
  display: flex;
  align-items: baseline;
  gap: .25rem;
}
.tier-amount {
  font-family: var(--font-heading);
  font-size: 2.2rem;
  font-weight: 700;
  color: var(--text-dark);
  line-height: 1;
}
.tier-amount--free {
  font-size: 2rem;
  color: var(--chumbo-flesh);
}
.tier-period {
  font-size: .85rem;
  color: var(--text-muted);
}

.tier-limits {
  font-family: var(--font-heading);
  font-size: .78rem;
  font-weight: 600;
  color: var(--chumbo-skin);
  background: rgba(155,29,53,.06);
  border: 1px solid rgba(155,29,53,.15);
  border-radius: var(--radius-sm);
  padding: .3rem .65rem;
  display: inline-block;
  width: fit-content;
}

.tier-card--free .tier-limits {
  color: #7a5000;
  background: rgba(244,165,35,.1);
  border-color: rgba(244,165,35,.35);
}

.tier-for {
  font-family: var(--font-heading);
  font-size: .9rem;
  font-weight: 600;
  color: var(--text-dark);
  line-height: 1.3;
}

.tier-note {
  font-size: .83rem;
  color: var(--text-muted);
  line-height: 1.6;
  flex: 1;
}

.tier-warning {
  font-size: .78rem;
  color: var(--text-muted);
  font-style: italic;
}

.tier-btn {
  width: 100%;
  justify-content: center;
  margin-top: auto;
  font-size: .9rem;
  padding: .65rem 1rem;
}

.pricing-cta-note {
  text-align: center;
  font-size: .875rem;
  color: var(--text-muted);
  border-top: 1px solid var(--border);
  padding-top: 1.75rem;
}
.pricing-cta-note a {
  color: var(--chumbo-skin);
  font-weight: 500;
}
</style>

