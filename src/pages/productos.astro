---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Productos — chumbo.io"
  description="Productos activos de chumbo.io: SILOE Generator en producción y DNIBridge alfa-v0.1.5 con firma electrónica Wacom STU y documento RGPD."
>
  <Nav />
  <main class="products-page">
    <section class="products-hero">
      <div class="container">
        <span class="section-label section-label--dark">Productos</span>
        <h1>Dos proyectos activos, foco total en producto real</h1>
        <p>
          chumbo.io desarrolla software vertical para problemas concretos.
          Hoy estamos empujando fuerte en cumplimiento de piscinas y verificacion de identidad digital.
        </p>
      </div>
    </section>

    <section class="products-grid-wrap">
      <div class="container products-grid">
        <article class="product-card product-card--main">
          <p class="product-status">En produccion · beta-v0.9.2-20260427</p>
          <h2>SILOE Generator</h2>
          <p class="product-sub">Libro Digital de Piscinas</p>
          <p>
            Sustituye el libro en papel/Excel, registra parametros diario, gestiona
            laboratorio y genera el XML oficial para SILOE conforme al RD 742/2013.
          </p>
          <ul>
            <li>Beta publica gratis temporal (1 establecimiento, 1 piscina)</li>
            <li>Upgrade transparente a Starter, Pro o Enterprise</li>
            <li>Infraestructura productiva con Stripe, Railway y Resend</li>
          </ul>
          <div class="product-actions">
            <a href="https://siloegenerator.chumbo.io/precios" class="btn btn-primary" target="_blank" rel="noopener">
              Probar gratis ->
            </a>
            <a href="/precios" class="btn btn-outline-dark">Ver planes</a>
          </div>
        </article>

        <article class="product-card">
          <p class="product-status">✅ alfa-v0.1.5-20260519 — firma electrónica Wacom STU operativa</p>
          <h2>DNIBridge</h2>
          <p class="product-sub">Verificación MiDNI + firma electrónica en recepción</p>
          <p>
            Ciclo completo de check-in para establecimientos de hospedaje: escanea y
            verifica criptográficamente el QR del DNI digital (MiDNI), recoge la
            firma electrónica del huésped en tableta Wacom STU y genera el
            documento de Registro de Entrada + Aviso de Privacidad en PDF —
            todo conforme al RD 255/2025 y al RGPD.
          </p>
          <ul>
            <li>✅ Verificación ECDSA P-256 con DNI real — operativa en producción</li>
            <li>✅ Firma electrónica en tableta <strong>Wacom STU-430 y STU-500</strong> con overlay LCD</li>
            <li>✅ PDF de Registro de Entrada + Aviso de Privacidad (RD 933/2021 + RGPD art. 13)</li>
            <li>✅ Hash SHA-256 + timestamp + ID de operación — trazabilidad legal completa</li>
            <li>Foco inicial: <strong>Canarias como laboratorio turístico</strong></li>
            <li>Próximo: integración con SES Hospedajes · certificados DGP productivos</li>
          </ul>
          <p class="product-note">
            Pre-release alfa — sin planes comerciales públicos todavía.
            <a href="mailto:soporte@chumbo.io">Contacta</a> si quieres probarlo en tu establecimiento.
          </p>
          <div class="product-actions">
            <a href="https://dnibridge.chumbo.io" class="btn btn-outline-dark" target="_blank" rel="noopener">
              Probar DNIBridge →
            </a>
            <a href="https://dnibridge.chumbo.io/docs/DNIBridge_Manual_Recepcion.pdf"
               class="btn btn-ghost" target="_blank" rel="noopener"
               title="Manual de operación para recepción (PDF)">
              📥 Manual recepción
            </a>
          </div>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
.products-page {
  background: var(--bg-light);
}

.products-hero {
  padding: 5rem 0 2.5rem;
}

.products-hero h1 {
  font-size: clamp(2rem, 5vw, 3.1rem);
  color: var(--text-dark);
  max-width: 780px;
  margin-bottom: .9rem;
}

.products-hero p {
  color: var(--text-muted);
  max-width: 760px;
}

.products-grid-wrap {
  padding: 1rem 0 6rem;
}

.products-grid {
  display: grid;
  gap: 1.25rem;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.product-card {
  background: var(--bg-white);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 1.8rem;
}

.product-card--main {
  border-color: rgba(155, 29, 53, 0.45);
  box-shadow: 0 0 0 2px rgba(155, 29, 53, 0.14);
}

.product-status {
  font-family: var(--font-heading);
  font-size: .74rem;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--chumbo-skin);
  margin-bottom: .5rem;
}

.product-card h2 {
  color: var(--text-dark);
  font-size: 1.5rem;
}

.product-sub {
  color: var(--text-muted);
  margin-bottom: .8rem;
}

.product-card p,
.product-card li {
  color: var(--text-muted);
  font-size: .93rem;
  line-height: 1.65;
}

.product-card ul {
  margin: .9rem 0 1.2rem;
  padding-left: 1.15rem;
}

.product-actions {
  display: flex;
  gap: .8rem;
  flex-wrap: wrap;
}

.product-note {
  margin-top: .95rem;
  font-style: italic;
}

.product-note a {
  color: var(--chumbo-skin);
  text-decoration: underline;
}

.btn-ghost {
  background: transparent;
  border: 1px solid var(--border, #e5e7eb);
  color: var(--text-muted, #6b7280);
  font-size: .85rem;
  padding: .5rem 1rem;
  border-radius: var(--radius-sm, 6px);
  text-decoration: none;
  transition: border-color .15s, color .15s;
}
.btn-ghost:hover {
  border-color: var(--chumbo-skin);
  color: var(--chumbo-skin);
  text-decoration: none;
}

@media (max-width: 820px) {
  .products-grid {
    grid-template-columns: 1fr;
  }
}
</style>

