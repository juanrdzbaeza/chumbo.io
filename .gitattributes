# Fuerza LF en todos los archivos de texto (Linux/macOS estándar)
* text=auto eol=lf

# Código fuente — siempre LF
*.astro  text eol=lf
*.ts     text eol=lf
*.js     text eol=lf
*.mjs    text eol=lf
*.cjs    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.css    text eol=lf
*.svg    text eol=lf
*.html   text eol=lf
*.toml   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.txt    text eol=lf
*.py     text eol=lf

# Binarios — sin conversión
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.pdf    binary

