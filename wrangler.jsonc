{
	// Configuración para Cloudflare Pages (SSG estático — sin Worker)
	// El build genera dist/ y Cloudflare Pages lo sirve directamente.
	// No usar "main" aquí: ese campo es para Workers SSR, no para Pages estáticas.
	"name": "chumbo-io",
	"pages_build_output_dir": "dist",
	"compatibility_date": "2026-03-17",
	"compatibility_flags": ["nodejs_compat"]
}